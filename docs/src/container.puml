@startuml
!NEW_C4_STYLE=1
!include <C4/C4_Container>

title eCommerce - System Container

LAYOUT_TOP_DOWN()

Person(customer, "Customer", "Uses the commerce capabilities")
Person(platformOperator, "Platform Operator", "Operates workflows and monitors platform health")

System_Ext(identityProvider, "Identity Provider", "Keycloak authenticates users and issues access tokens")
System_Ext(paymentProvider, "Payment Provider", "Authorizes, captures and refunds payments")
System_Ext(notificationProvider, "Notification Provider", "Delivers email, SMS and push notifications")
System_Ext(observabilityPlatform, "Observability Platform", "Prometheus, Loki, Tempo and Grafana store, correlate and visualize telemetry")

System_Boundary(ecommercePlatform, "E-Commerce Platform") {
    Container(apiGateway, "API Gateway", "Kubernetes Gateway API", "Terminates TLS, enforces edge policies and routes authenticated requests")

    Container_Boundary(customerProductCapabilities, "Customer and Product Capabilities") {
        Container(catalogService, "Catalog Service", "Java 25 / Spring Boot 4", "Owns products, categories and product media metadata")
        Container(pricingService, "Pricing Service", "Java 25 / Spring Boot 4", "Calculates prices, discounts and promotions")
        Container(cartService, "Cart Service", "Java 25 / Spring Boot 4", "Maintains short-lived customer shopping carts")
        Container(profileService, "Profile Service", "Java 25 / Spring Boot 4", "Manages customer profiles and delivery addresses")
        Container(reviewService, "Review Service", "Java 25 / Spring Boot 4", "Manages product ratings and reviews")
    }

    Container_Boundary(orderLifecycleCapabilities, "Order Lifecycle Capabilities") {
        Container(orderService, "Order Service", "Java 25 / Spring Boot 4 / Temporal SDK", "Owns order state and durable order workflow definitions")
        Container(inventoryService, "Inventory Service", "Java 25 / Spring Boot 4 / Temporal SDK", "Reserves, commits and releases stock")
        Container(paymentService, "Payment Service", "Java 25 / Spring Boot 4 / Temporal SDK", "Coordinates payment authorization, capture and refunds")
        Container(fulfillmentService, "Fulfillment Service", "Java 25 / Spring Boot 4 / Temporal SDK", "Plans shipments and tracks delivery progress")
    }

    Container_Boundary(platformCapabilities, "Platform Capabilities") {
        ContainerQueue(kafkaCluster, "Event Streaming Platform", "Apache Kafka cluster", "Distributes versioned product, order, inventory, payment and fulfillment events")
        Container(temporalCluster, "Workflow Orchestration", "Temporal cluster", "Persists durable execution state and dispatches workflow and activity tasks")
        Container(notificationService, "Notification Service", "Java 25 / Spring Boot 4", "Consumes business events and sends customer notifications")
        Container(telemetryCollector, "Telemetry Collector", "OpenTelemetry Collector", "Receives and enriches telemetry from every platform container")

        ContainerDb(serviceDatabases, "Service-Owned Databases", "PostgreSQL cluster", "Runs an isolated database per stateful service; cross-service database access is forbidden")
        ContainerDb(cartStore, "Cart Store", "Redis cluster", "Stores active carts with expiration")
        ContainerDb(temporalDatabase, "Temporal Persistence", "PostgreSQL", "Stores workflow state, execution history and visibility data")
        Container(temporalUi, "Workflow Operations UI", "Temporal Web UI", "Inspects workflow executions, retries and failures")
    }
}

Rel(customer, apiGateway, "Uses commerce APIs", "HTTPS / JSON")
Rel(customer, identityProvider, "Authenticates", "OAuth 2.0 / OpenID Connect")
Rel(apiGateway, identityProvider, "Validates tokens and loads signing keys", "OIDC / JWKS")

Rel(apiGateway, catalogService, "Routes catalog requests", "HTTP / REST")
Rel(apiGateway, cartService, "Routes cart requests", "HTTP / REST")
Rel(apiGateway, profileService, "Routes profile requests", "HTTP / REST")
Rel(apiGateway, reviewService, "Routes review requests", "HTTP / REST")
Rel(apiGateway, orderService, "Routes order requests", "HTTP / REST")

Rel(catalogService, kafkaCluster, "Publishes product events", "Kafka")
Rel(orderService, kafkaCluster, "Publishes order lifecycle events", "Kafka")
Rel(kafkaCluster, pricingService, "Delivers product change events", "Kafka")
Rel(kafkaCluster, notificationService, "Delivers customer notification events", "Kafka")

Rel(orderService, temporalCluster, "Runs durable order workflows", "Temporal SDK / gRPC")
Rel(inventoryService, temporalCluster, "Executes inventory activities", "Temporal task queue")
Rel(paymentService, temporalCluster, "Executes payment activities", "Temporal task queue")
Rel(fulfillmentService, temporalCluster, "Executes fulfillment activities", "Temporal task queue")
Rel_D(temporalCluster, temporalDatabase, "Persists workflow state and history", "SQL")
Rel(temporalUi, temporalCluster, "Queries and controls workflow executions", "Temporal API")
Rel(platformOperator, temporalUi, "Investigates and controls workflows", "HTTPS")

Rel_D(profileService, serviceDatabases, "Uses isolated profile database", "JDBC")
Rel_D(orderService, serviceDatabases, "Uses isolated order database", "JDBC")
Rel_D(cartService, cartStore, "Stores active carts", "Redis protocol")

Rel(paymentService, paymentProvider, "Authorizes, captures and refunds payments", "HTTPS / REST")
Rel(notificationService, notificationProvider, "Sends transactional messages", "HTTPS / provider APIs")

Rel(telemetryCollector, observabilityPlatform, "Exports metrics, logs and traces", "OTLP / Prometheus remote write")
Rel(platformOperator, observabilityPlatform, "Views dashboards and investigates incidents", "HTTPS")

Lay_R(customer, platformOperator)
Lay_D(customer, apiGateway)

Lay_R(catalogService, pricingService)
Lay_R(pricingService, cartService)
Lay_R(cartService, profileService)
Lay_R(profileService, reviewService)

Lay_R(orderService, inventoryService)
Lay_R(inventoryService, paymentService)
Lay_R(paymentService, fulfillmentService)

Lay_R(kafkaCluster, temporalCluster)
Lay_R(temporalCluster, notificationService)
Lay_R(notificationService, telemetryCollector)

Lay_R(serviceDatabases, cartStore)
Lay_R(cartStore, temporalDatabase)
Lay_R(temporalDatabase, temporalUi)

Lay_D(catalogService, orderService)
Lay_D(orderService, kafkaCluster)

Lay_L(apiGateway, identityProvider)
Lay_R(paymentService, paymentProvider)
Lay_R(notificationService, notificationProvider)
Lay_R(telemetryCollector, observabilityPlatform)

SHOW_LEGEND()
@enduml
